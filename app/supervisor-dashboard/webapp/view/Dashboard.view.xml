<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    controllerName="sepur.supervisor.controller.Dashboard"
    displayBlock="true">

    <App id="supervisorDashboardApp">
        <Page showHeader="false" class="supervisorPage">
            <content>
                <HBox id="layoutRoot" class="pageLayout">

                    <VBox id="sidebar" class="sideNav">
                        <VBox class="brandArea" alignItems="Center">
                            <Image
                                src="https://www.sepur.com/wp-content/uploads/2025/01/logo-sepur-insertion-e1736954850722.png"
                                class="sepurLogo"
                                decorative="false"
                                alt="SEPUR" />
                        </VBox>

                        <VBox class="menuArea">
                            <Button id="btnMenuDashboard" text="Dashboard" icon="sap-icon://business-objects-experience" class="menuButton activeMenu" press=".onNavigateSection">
                                <customData><core:CustomData key="section" value="dashboard" writeToDom="false" /></customData>
                            </Button>
                            <Button id="btnMenuTours" text="Tournées" icon="sap-icon://map" class="menuButton" press=".onNavigateSection">
                                <customData><core:CustomData key="section" value="tours" writeToDom="false" /></customData>
                            </Button>
                            <Button id="btnMenuRoadmaps" text="Roadmaps" icon="sap-icon://journey-arrive" class="menuButton" press=".onNavigateSection">
                                <customData><core:CustomData key="section" value="roadmaps" writeToDom="false" /></customData>
                            </Button>
                            <Button id="btnMenuIntegration" text="Intégration" icon="sap-icon://sales-order" class="menuButton" press=".onNavigateSection">
                                <customData><core:CustomData key="section" value="integration" writeToDom="false" /></customData>
                            </Button>
                            <Button id="btnMenuHistory" text="Historique" icon="sap-icon://history" class="menuButton" press=".onNavigateSection">
                                <customData><core:CustomData key="section" value="history" writeToDom="false" /></customData>
                            </Button>
                        </VBox>

                        <VBox class="bottomArea">
                            <Button text="Actualiser" icon="sap-icon://refresh" class="menuButton" press=".onRefresh" />
                            <Button text="Déconnexion" icon="sap-icon://log" class="menuButton logoutButton" press=".onLogout" />
                        </VBox>
                    </VBox>

                    <VBox id="mainContent" class="mainArea" busy="{view>/busy}" busyIndicatorDelay="0">
                        <HBox class="topBar" justifyContent="SpaceBetween" alignItems="Center">
                            <HBox alignItems="Center" class="headerBrand">
                                <VBox>
                                    <Title text="Espace Superviseur" level="H2" class="topTitle" />
                                    <Text text="Validation des tournées et roadmaps" class="topSubtitle" />
                                </VBox>
                            </HBox>
                            <HBox alignItems="Center" class="topActions">
                                <Button id="btnSupervisorNotifications" icon="sap-icon://bell" text="{view>/notifications/count}" press=".onOpenNotifications" class="notificationButton sapUiSmallMarginBegin" />
                                <Button icon="sap-icon://refresh" press=".onRefresh" class="refreshButton sapUiSmallMarginBegin" />
                                <Avatar initials="{view>/userInitials}" displaySize="S" backgroundColor="Accent6" class="topAvatar" />
                            </HBox>
                        </HBox>

                        <ScrollContainer id="mainScroll" class="dashboardScroll" vertical="true" horizontal="false" height="100%">
                            <VBox id="dynamicContent" class="dynamicContentArea dashboardBody" />
                        </ScrollContainer>
                    </VBox>
                </HBox>
            </content>
        </Page>
    </App>
</mvc:View>
