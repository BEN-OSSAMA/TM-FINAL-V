<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <VBox class="sectionContainer">
        <HBox class="sectionHeaderBar" justifyContent="SpaceBetween" alignItems="Center" wrap="Wrap">
            <VBox>
                <Title text="Tournées à valider" level="H3" class="sectionTitle" />
                <Text text="Contrôlez les tournées soumises par le planificateur" class="sectionSubtitle" />
            </VBox>
            <HBox wrap="Wrap">
                <Button text="Détails" icon="sap-icon://detail-view" enabled="{view>/toursSection/hasSelection}" press=".onViewTourDetails" />
                <Button text="Valider" icon="sap-icon://accept" type="Accept" enabled="{view>/toursSection/hasSelection}" press=".onValidateSelectedTour" class="sapUiSmallMarginBegin" />
                <Button text="Rejeter" icon="sap-icon://decline" type="Reject" enabled="{view>/toursSection/hasSelection}" press=".onRejectSelectedTour" class="sapUiSmallMarginBegin" />
                <Button text="Actualiser" icon="sap-icon://refresh" press=".onRefreshToursSection" class="sapUiSmallMarginBegin" />
            </HBox>
        </HBox>
        <Table id="supervisorToursTable" class="sectionTable" items="{view>/toursSection/items}" mode="SingleSelectLeft" selectionChange=".onTourSelectionChange" growing="true">
            <columns>
                <Column><Text text="N° tournée" /></Column>
                <Column><Text text="Date" /></Column>
                <Column><Text text="Client" /></Column>
                <Column><Text text="Matériau" /></Column>
                <Column hAlign="End"><Text text="Quantité" /></Column>
                <Column><Text text="Unité" /></Column>
                <Column><Text text="Statut" /></Column>
            </columns>
            <items>
                <ColumnListItem>
                    <cells>
                        <Text text="{view>tourCode}" />
                        <Text text="{path: 'view>tourDate', type: 'sap.ui.model.type.Date', formatOptions: { style: 'medium' }}" />
                        <Text text="{view>clientName}" />
                        <Text text="{view>materialName}" />
                        <Text text="{view>quantity}" />
                        <Text text="{view>unitOfMeasure}" />
                        <ObjectStatus text="{view>status}" state="Warning" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </VBox>
</core:FragmentDefinition>
