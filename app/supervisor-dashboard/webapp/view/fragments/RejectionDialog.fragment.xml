<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Dialog id="rejectionDialog" title="Motif de rejet" contentWidth="28rem">
        <content>
            <TextArea value="{view>/rejectionDialog/reason}" rows="4" width="100%" placeholder="Motif obligatoire" class="sapUiSmallMargin" />
        </content>
        <beginButton>
            <Button text="Confirmer le rejet" type="Reject" press=".onConfirmRejection" />
        </beginButton>
        <endButton>
            <Button text="Annuler" press=".onCancelRejection" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
