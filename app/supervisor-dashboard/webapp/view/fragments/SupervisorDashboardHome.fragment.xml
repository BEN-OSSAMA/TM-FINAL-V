<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:viz="sap.viz.ui5.controls" xmlns:viz.data="sap.viz.ui5.data" xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">
    <VBox class="sectionContainer">
        <FlexBox id="kpiGrid" class="kpiGridProfessional" wrap="Wrap">
            <GenericTile header="Total tournées" frameType="TwoByOne" class="sapKpiTile" press=".onNavigateToTours">
                <tileContent><TileContent><NumericContent value="{view>/tourStats/totalTours}" icon="sap-icon://map" /></TileContent></tileContent>
            </GenericTile>
            <GenericTile header="En attente" frameType="TwoByOne" class="sapKpiTile" press=".onNavigateToTours">
                <tileContent><TileContent><NumericContent value="{view>/tourStats/pendingTours}" icon="sap-icon://pending" valueColor="Critical" /></TileContent></tileContent>
            </GenericTile>
            <GenericTile header="Validées" frameType="TwoByOne" class="sapKpiTile" press=".onNavigateToTours">
                <tileContent><TileContent><NumericContent value="{view>/tourStats/acceptedTours}" icon="sap-icon://accept" valueColor="Good" /></TileContent></tileContent>
            </GenericTile>
            <GenericTile header="Rejetées" frameType="TwoByOne" class="sapKpiTile" press=".onNavigateToTours">
                <tileContent><TileContent><NumericContent value="{view>/tourStats/rejectedTours}" icon="sap-icon://message-error" valueColor="Error" /></TileContent></tileContent>
            </GenericTile>
            <GenericTile header="Roadmaps" frameType="TwoByOne" class="sapKpiTile" press=".onNavigateToRoadmaps">
                <tileContent><TileContent><NumericContent value="{view>/roadmapStats/totalRoadmaps}" icon="sap-icon://journey-arrive" /></TileContent></tileContent>
            </GenericTile>
            <GenericTile header="Intégration" frameType="TwoByOne" class="sapKpiTile" press=".onNavigateToIntegration">
                <tileContent><TileContent><NumericContent value="{view>/integrationStats/pendingCount}" icon="sap-icon://sales-order" valueColor="Critical" /></TileContent></tileContent>
            </GenericTile>
        </FlexBox>
        <HBox class="chartsRow" wrap="Wrap">
            <VBox class="chartCard">
                <Title text="Statistiques des tournées" level="H4" class="cardTitle" />
                <viz:VizFrame id="supervisorTourDonutChart" uiConfig="{applicationSet:'fiori'}" vizType="donut" width="100%" height="280px">
                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{view>/tourDonutData}">
                            <viz.data:dimensions><viz.data:DimensionDefinition name="Statut" value="{view>label}" /></viz.data:dimensions>
                            <viz.data:measures><viz.data:MeasureDefinition name="Nombre" value="{view>value}" /></viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>
                    <viz:feeds>
                        <viz.feeds:FeedItem uid="size" type="Measure" values="Nombre" />
                        <viz.feeds:FeedItem uid="color" type="Dimension" values="Statut" />
                    </viz:feeds>
                </viz:VizFrame>
            </VBox>
            <VBox class="chartCard">
                <Title text="Statistiques des roadmaps" level="H4" class="cardTitle" />
                <viz:VizFrame id="supervisorRoadmapBarChart" uiConfig="{applicationSet:'fiori'}" vizType="column" width="100%" height="280px">
                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{view>/roadmapBarData}">
                            <viz.data:dimensions><viz.data:DimensionDefinition name="Statut" value="{view>label}" /></viz.data:dimensions>
                            <viz.data:measures><viz.data:MeasureDefinition name="Nombre" value="{view>value}" /></viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>
                    <viz:feeds>
                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Nombre" />
                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Statut" />
                    </viz:feeds>
                </viz:VizFrame>
            </VBox>
        </HBox>
    </VBox>
</core:FragmentDefinition>
