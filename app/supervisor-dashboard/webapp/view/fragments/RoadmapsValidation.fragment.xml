<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <VBox class="sectionContainer">
        <HBox class="sectionHeaderBar" justifyContent="SpaceBetween" alignItems="Center" wrap="Wrap">
            <VBox>
                <Title text="Roadmaps à valider" level="H3" class="sectionTitle" />
                <Text text="Vérifiez les roadmaps mensuelles avant validation" class="sectionSubtitle" />
            </VBox>
            <HBox wrap="Wrap">
                <Button text="Valider" icon="sap-icon://accept" type="Accept" enabled="{view>/roadmapsSection/hasSelection}" press=".onValidateSelectedRoadmap" />
                <Button text="Rejeter" icon="sap-icon://decline" type="Reject" enabled="{view>/roadmapsSection/hasSelection}" press=".onRejectSelectedRoadmap" class="sapUiSmallMarginBegin" />
                <Button text="Actualiser" icon="sap-icon://refresh" press=".onRefreshRoadmapsSection" class="sapUiSmallMarginBegin" />
            </HBox>
        </HBox>
        <Table id="supervisorRoadmapsTable" class="sectionTable" items="{view>/roadmapsSection/items}" mode="SingleSelectLeft" selectionChange=".onRoadmapSelectionChange" growing="true">
            <columns>
                <Column><Text text="N° roadmap" /></Column>
                <Column><Text text="Client" /></Column>
                <Column hAlign="Center"><Text text="Mois" /></Column>
                <Column hAlign="Center"><Text text="Année" /></Column>
                <Column><Text text="Statut" /></Column>
            </columns>
            <items>
                <ColumnListItem>
                    <cells>
                        <Text text="{view>roadmapCode}" />
                        <Text text="{view>clientName}" />
                        <Text text="{view>month}" />
                        <Text text="{view>year}" />
                        <ObjectStatus text="{view>status}" state="Warning" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </VBox>
</core:FragmentDefinition>
