<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <VBox class="sectionContainer">
        <HBox class="sectionHeaderBar" justifyContent="SpaceBetween" alignItems="Center" wrap="Wrap">
            <VBox>
                <Title text="Tournées rejetées" level="H3" class="sectionTitle" />
                <Text text="Corrigez les tournées rejetées puis resoumettez-les au superviseur" class="sectionSubtitle" />
            </VBox>
            <HBox class="sectionToolbar" wrap="Wrap">
                <Button text="Corriger" icon="sap-icon://edit" type="Emphasized" enabled="{/rejectedToursSection/hasSelection}" press=".onEditRejectedTour" />
                <Button text="Actualiser" icon="sap-icon://refresh" type="Default" press=".onRefreshRejectedToursSection" class="sapUiSmallMarginBegin" />
            </HBox>
        </HBox>

        <Table
            id="rejectedToursTable"
            class="sectionTable"
            items="{/rejectedToursSection/items}"
            mode="SingleSelectLeft"
            growing="true"
            selectionChange=".onRejectedTourSelectionChange"
            noDataText="Aucune tournée rejetée">
            <columns>
                <Column><Text text="N° tournée" /></Column>
                <Column><Text text="Date" /></Column>
                <Column><Text text="Client" /></Column>
                <Column><Text text="Matériau" /></Column>
                <Column><Text text="Motif de rejet" /></Column>
            </columns>
            <items>
                <ColumnListItem>
                    <cells>
                        <Text text="{tourCode}" />
                        <Text text="{path: 'tourDate', type: 'sap.ui.model.type.Date', formatOptions: { style: 'medium' }}" />
                        <Text text="{clientName}" />
                        <Text text="{materialName}" />
                        <Text text="{rejectionReason}" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </VBox>
</core:FragmentDefinition>
