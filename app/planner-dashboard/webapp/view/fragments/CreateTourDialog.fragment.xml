<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <Dialog
        id="createTourDialog"
        title="Créer une tournée"
        contentWidth="36rem"
        class="createTourDialog"
        draggable="true"
        resizable="true">

        <content>
            <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="4"
                labelSpanS="12"
                emptySpanXL="0"
                emptySpanL="0"
                emptySpanM="0"
                emptySpanS="0"
                columnsXL="1"
                columnsL="1"
                columnsM="1"
                class="sapUiSmallMarginTop">

                <f:content>
                    <Label text="N° tournée" />
                    <Input
                        value="{/tourDialog/tourCode}"
                        editable="false"
                        placeholder="Généré automatiquement" />

                    <Label text="Date de collecte" required="true" />
                    <DatePicker
                        id="dpCollectionDate"
                        value="{/tourDialog/collectionDate}"
                        valueFormat="yyyy-MM-dd"
                        displayFormat="medium"
                        placeholder="Sélectionner une date" />

                    <Label text="Client" required="true" />
                    <ComboBox
                        id="cbClient"
                        selectedKey="{/tourDialog/client_ID}"
                        items="{/tourDialog/clients}"
                        placeholder="Sélectionner un client"
                        showSecondaryValues="true">
                        <core:Item key="{ID}" text="{name}" additionalText="{code}" />
                    </ComboBox>

                    <Label text="Matériau" required="true" />
                    <ComboBox
                        id="cbMaterial"
                        selectedKey="{/tourDialog/material_ID}"
                        selectionChange=".onMaterialSelectionChange"
                        items="{/tourDialog/materials}"
                        placeholder="Sélectionner un matériau"
                        showSecondaryValues="true">
                        <core:Item key="{ID}" text="{description}" additionalText="{materialCode}" />
                    </ComboBox>

                    <Label text="Quantité" required="true" />
                    <Input
                        id="inpQuantity"
                        value="{/tourDialog/quantity}"
                        type="Number"
                        placeholder="0" />

                    <Label text="Unité de mesure" required="true" />
                    <Input
                        id="inpUnitOfMeasure"
                        value="{/tourDialog/unitOfMeasure}"
                        placeholder="ex. KG" />

                    <Label text="Ressources humaines" />
                    <MultiComboBox
                        id="mcbHumanResources"
                        selectedKeys="{/tourDialog/humanResourceIds}"
                        items="{/tourDialog/humanResources}"
                        placeholder="Sélectionner des ressources humaines">
                        <core:Item key="{ID}" text="{fullName}" additionalText="{employeeCode}" />
                    </MultiComboBox>

                    <Label text="Ressources matérielles" />
                    <MultiComboBox
                        id="mcbMaterialResources"
                        selectedKeys="{/tourDialog/materialResourceIds}"
                        items="{/tourDialog/materialResources}"
                        placeholder="Sélectionner des ressources matérielles">
                        <core:Item key="{ID}" text="{name}" additionalText="{equipmentCode}" />
                    </MultiComboBox>

                    <Label text="Remarques" />
                    <TextArea
                        value="{/tourDialog/remarks}"
                        rows="3"
                        width="100%"
                        placeholder="Remarques optionnelles" />
                </f:content>
            </f:SimpleForm>
        </content>

        <beginButton>
            <Button
                text="Créer"
                type="Emphasized"
                press=".onConfirmCreateTour" />
        </beginButton>
        <endButton>
            <Button
                text="Annuler"
                press=".onCancelCreateTour" />
        </endButton>

    </Dialog>

</core:FragmentDefinition>
