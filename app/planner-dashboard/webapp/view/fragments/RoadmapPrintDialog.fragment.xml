<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Dialog id="roadmapPrintDialog" title="Feuille de route SEPUR" contentWidth="48rem" resizable="true" draggable="true">
        <content>
            <VBox class="sapUiSmallMargin">
                <Image src="{/roadmapPrint/logoUrl}" width="8rem" class="sapUiSmallMarginBottom" />
                <Title text="{/roadmapPrint/roadmapCode}" level="H3" />
                <Text text="Client : {/roadmapPrint/clientName} ({/roadmapPrint/clientCode})" />
                <Text text="Période : {/roadmapPrint/month}/{/roadmapPrint/year} — Statut : {/roadmapPrint/status}" class="sapUiTinyMarginTop" />
                <Title text="Tournées affectées" level="H4" class="sapUiMediumMarginTop" />
                <Table items="{/roadmapPrint/tours}" growing="true">
                    <columns>
                        <Column><Text text="N° tournée" /></Column>
                        <Column><Text text="Date" /></Column>
                        <Column><Text text="Matériau" /></Column>
                        <Column hAlign="End"><Text text="Qté" /></Column>
                        <Column><Text text="Ress. humaines" /></Column>
                        <Column><Text text="Ress. matérielles" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{tourCode}" />
                                <Text text="{tourDate}" />
                                <Text text="{materialName}" />
                                <Text text="{quantity}" />
                                <Text text="{humanResources}" />
                                <Text text="{materialResources}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
                <Title text="Quantités groupées par matériau" level="H4" class="sapUiMediumMarginTop" />
                <Table items="{/roadmapPrint/materialGroups}">
                    <columns>
                        <Column><Text text="Matériau" /></Column>
                        <Column hAlign="End"><Text text="Quantité totale" /></Column>
                        <Column><Text text="Unité" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{materialName}" />
                                <Text text="{totalQuantity}" />
                                <Text text="{unitOfMeasure}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
        <endButton>
            <Button text="Fermer" press=".onCloseRoadmapPrint" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
