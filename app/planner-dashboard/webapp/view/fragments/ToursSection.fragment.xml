<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <VBox class="sectionContainer">

        <HBox class="sectionHeaderBar" justifyContent="SpaceBetween" alignItems="Center" wrap="Wrap">
            <VBox>
                <Title text="Tournées de collecte" level="H3" class="sectionTitle" />
                <Text text="Création et suivi des tournées de collecte" class="sectionSubtitle" />
            </VBox>
            <HBox class="sectionToolbar" wrap="Wrap">
                <Button
                    text="Créer"
                    icon="sap-icon://add"
                    type="Emphasized"
                    press=".onOpenCreateTourDialog"
                    class="btnCreate" />
                <Button
                    id="btnDeleteTours"
                    text="Supprimer"
                    icon="sap-icon://delete"
                    type="Default"
                    enabled="{/toursSection/hasSelection}"
                    press=".onDeleteSelectedTours"
                    class="sapUiSmallMarginBegin" />
                <Button
                    text="Actualiser"
                    icon="sap-icon://refresh"
                    type="Default"
                    press=".onRefreshToursSection"
                    class="sapUiSmallMarginBegin" />
            </HBox>
        </HBox>

        <Table
            id="toursTable"
            class="sectionTable"
            items="{/toursSection/items}"
            mode="MultiSelect"
            growing="true"
            growingThreshold="20"
            selectionChange=".onTourSelectionChange"
            noDataText="Aucune tournée trouvée">

            <columns>
                <Column><Text text="N° tournée" /></Column>
                <Column><Text text="Date de collecte" /></Column>
                <Column><Text text="Client" /></Column>
                <Column><Text text="Matériau" /></Column>
                <Column hAlign="End"><Text text="Quantité" /></Column>
                <Column><Text text="Unité" /></Column>
                <Column><Text text="Ress. humaines" /></Column>
                <Column><Text text="Ress. matérielles" /></Column>
                <Column><Text text="Statut" /></Column>
                <Column><Text text="Remarques" /></Column>
            </columns>

            <items>
                <ColumnListItem>
                    <cells>
                        <Text text="{tourCode}" />
                        <Text text="{path: 'tourDate', type: 'sap.ui.model.type.Date', formatOptions: { style: 'medium' }}" />
                        <Text text="{clientName}" />
                        <Text text="{materialName}" />
                        <Text text="{quantity}" />
                        <Text text="{unitOfMeasure}" />
                        <Text text="{humanResourcesLabel}" />
                        <Text text="{materialResourcesLabel}" />
                        <ObjectStatus
                            text="{status}"
                            state="{= ${status} === 'VALIDATED' ? 'Success' : (${status} === 'REJECTED' ? 'Error' : 'Warning') }" />
                        <Text text="{description}" />
                    </cells>
                </ColumnListItem>
            </items>

        </Table>

    </VBox>

</core:FragmentDefinition>
