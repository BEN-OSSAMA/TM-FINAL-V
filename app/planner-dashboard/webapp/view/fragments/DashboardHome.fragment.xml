<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

    <VBox class="sectionContainer">

        <FlexBox
            id="kpiGrid"
            class="kpiGridProfessional"
            wrap="Wrap"
            justifyContent="Start"
            alignItems="Start">

            <GenericTile
                header="Total tournées"
                subheader="Toutes les tournées enregistrées"
                frameType="TwoByOne"
                class="sapKpiTile"
                press=".onNavigateToTours">
                <tileContent>
                    <TileContent footer="Tournées">
                        <NumericContent
                            value="{/stats/totalTours}"
                            icon="sap-icon://map"
                            valueColor="Neutral"
                            indicator="None"
                            withMargin="false" />
                    </TileContent>
                </tileContent>
            </GenericTile>

            <GenericTile
                header="Tournées créées"
                subheader="En attente de traitement"
                frameType="TwoByOne"
                class="sapKpiTile"
                press=".onNavigateToTours">
                <tileContent>
                    <TileContent footer="À suivre">
                        <NumericContent
                            value="{/stats/createdTours}"
                            icon="sap-icon://pending"
                            valueColor="Critical"
                            indicator="None"
                            withMargin="false" />
                    </TileContent>
                </tileContent>
            </GenericTile>

            <GenericTile
                header="Tournées validées"
                subheader="Acceptées par le superviseur"
                frameType="TwoByOne"
                class="sapKpiTile"
                press=".onNavigateToTours">
                <tileContent>
                    <TileContent footer="Validées">
                        <NumericContent
                            value="{/stats/validatedTours}"
                            icon="sap-icon://accept"
                            valueColor="Good"
                            indicator="Up"
                            withMargin="false" />
                    </TileContent>
                </tileContent>
            </GenericTile>

            <GenericTile
                header="Tournées rejetées"
                subheader="Correction nécessaire"
                frameType="TwoByOne"
                class="sapKpiTile"
                press=".onNavigateToRejectedTours">
                <tileContent>
                    <TileContent footer="À corriger">
                        <NumericContent
                            value="{/stats/rejectedTours}"
                            icon="sap-icon://message-error"
                            valueColor="Error"
                            indicator="Down"
                            withMargin="false" />
                    </TileContent>
                </tileContent>
            </GenericTile>

            <GenericTile
                header="Total roadmaps"
                subheader="Roadmaps disponibles"
                frameType="TwoByOne"
                class="sapKpiTile"
                press=".onNavigateToRoadmaps">
                <tileContent>
                    <TileContent footer="Roadmaps">
                        <NumericContent
                            value="{/stats/totalRoadmaps}"
                            icon="sap-icon://journey-arrive"
                            valueColor="Neutral"
                            indicator="None"
                            withMargin="false" />
                    </TileContent>
                </tileContent>
            </GenericTile>

            <GenericTile
                header="Roadmaps créées"
                subheader="En attente de traitement"
                frameType="TwoByOne"
                class="sapKpiTile"
                press=".onNavigateToRoadmaps">
                <tileContent>
                    <TileContent footer="À traiter">
                        <NumericContent
                            value="{/stats/createdRoadmaps}"
                            icon="sap-icon://pending"
                            valueColor="Critical"
                            indicator="None"
                            withMargin="false" />
                    </TileContent>
                </tileContent>
            </GenericTile>

            <GenericTile
                header="Roadmaps validées"
                subheader="Acceptées par le superviseur"
                frameType="TwoByOne"
                class="sapKpiTile"
                press=".onNavigateToRoadmaps">
                <tileContent>
                    <TileContent footer="Validées">
                        <NumericContent
                            value="{/stats/validatedRoadmaps}"
                            icon="sap-icon://accept"
                            valueColor="Good"
                            indicator="Up"
                            withMargin="false" />
                    </TileContent>
                </tileContent>
            </GenericTile>

            <GenericTile
                header="Roadmaps rejetées"
                subheader="Correction nécessaire"
                frameType="TwoByOne"
                class="sapKpiTile"
                press=".onNavigateToRejectedTours">
                <tileContent>
                    <TileContent footer="À corriger">
                        <NumericContent
                            value="{/stats/rejectedRoadmaps}"
                            icon="sap-icon://message-error"
                            valueColor="Error"
                            indicator="Down"
                            withMargin="false" />
                    </TileContent>
                </tileContent>
            </GenericTile>

        </FlexBox>

        <HBox class="chartsRow" wrap="Wrap">

            <VBox class="chartCard">
                <HBox class="cardHeader" justifyContent="SpaceBetween" alignItems="Center">
                    <HBox alignItems="Center">
                        <VBox class="cardIconBox">
                            <core:Icon src="sap-icon://donut-chart" class="cardHeaderIcon" />
                        </VBox>
                        <VBox>
                            <Title text="Statistiques des tournées" level="H4" class="cardTitle" />
                            <Text text="Répartition par statut" class="mutedText" />
                        </VBox>
                    </HBox>
                    <Button
                        icon="sap-icon://refresh"
                        type="Transparent"
                        press=".onRefresh"
                        tooltip="Actualiser" />
                </HBox>

                <viz:VizFrame
                    id="tourStatusChart"
                    uiConfig="{applicationSet:'fiori'}"
                    vizType="donut"
                    width="100%"
                    height="300px">
                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{/tourChartData}">
                            <viz.data:dimensions>
                                <viz.data:DimensionDefinition name="Statut" value="{status}" />
                            </viz.data:dimensions>
                            <viz.data:measures>
                                <viz.data:MeasureDefinition name="Nombre" value="{total}" />
                            </viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>
                    <viz:feeds>
                        <viz.feeds:FeedItem uid="size" type="Measure" values="Nombre" />
                        <viz.feeds:FeedItem uid="color" type="Dimension" values="Statut" />
                    </viz:feeds>
                </viz:VizFrame>
            </VBox>

            <VBox class="chartCard">
                <HBox class="cardHeader" justifyContent="SpaceBetween" alignItems="Center">
                    <HBox alignItems="Center">
                        <VBox class="cardIconBox">
                            <core:Icon src="sap-icon://bar-chart" class="cardHeaderIcon" />
                        </VBox>
                        <VBox>
                            <Title text="Statistiques des roadmaps" level="H4" class="cardTitle" />
                            <Text text="Répartition par statut" class="mutedText" />
                        </VBox>
                    </HBox>
                    <Button
                        icon="sap-icon://refresh"
                        type="Transparent"
                        press=".onRefresh"
                        tooltip="Actualiser" />
                </HBox>

                <viz:VizFrame
                    id="roadmapStatusChart"
                    uiConfig="{applicationSet:'fiori'}"
                    vizType="column"
                    width="100%"
                    height="300px">
                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{/roadmapChartData}">
                            <viz.data:dimensions>
                                <viz.data:DimensionDefinition name="Statut" value="{status}" />
                            </viz.data:dimensions>
                            <viz.data:measures>
                                <viz.data:MeasureDefinition name="Nombre" value="{total}" />
                            </viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>
                    <viz:feeds>
                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Nombre" />
                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Statut" />
                    </viz:feeds>
                </viz:VizFrame>
            </VBox>

        </HBox>

    </VBox>

</core:FragmentDefinition>
